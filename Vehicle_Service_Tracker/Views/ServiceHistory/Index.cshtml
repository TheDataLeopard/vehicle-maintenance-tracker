@model Vehicle_Service_Tracker.Models.Vehicle

@{
    ViewData["Title"] = "Service History";
}

<h2 class="mb-4">Service History</h2>

<!-- Vehicle summary-->
<div class="card mb-4">
    <div class="card-body d-flex align-items-center">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath"
                class="img-thumbnail me-3"
                style="max-height:120px;" />
        }

        <div>
            <h5 class="mb-1">@Model.Name</h5>
            <p class="mb-0 text-muted">
                Mileage: @Model.CurrentMileage km
            </p>
        </div>
    </div>
</div>

<a class="btn btn-primary mb-3"
    asp-action="Create"
    asp-route-vehicleId="@Model.VehicleId">
    Add Service Record
</a>

<a class="btn btn-outline-success mb-3 ms-2"
   asp-action="Download"
   asp-route-vehicleId="@Model.VehicleId">
    Download CSV
</a>

<a class="btn btn-outline-danger mb-3 ms-2"
   asp-action="DownloadPdf"
   asp-route-vehicleId="@Model.VehicleId">
    Download PDF
</a>

@if (!Model.ServiceHistories.Any())
{
    <div class="alert alert-info">
        No service history records found for this vehicle.
    </div>
}
else
{
    <div class="row">
        @foreach (var service in Model.ServiceHistories
       .OrderByDescending(s => s.ServiceDate))
        {
            var collapseId = $"service-{service.ServiceHistoryId}";

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">

                        <h5 class="card-title mb-1">
                            @service.ServiceType
                        </h5>

                        <p class="text-muted mb-2">
                            @service.ServiceDate.ToShortDateString()
                        </p>

                        <p class="mb-2">
                            Mileage: <strong>@service.MileageAtService km</strong>
                        </p>

                        <button class="btn btn-sm btn-outline-primary"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId"
                                aria-expanded="false">
                            Details
                        </button>

                        <div class="collapse mt-3" id="@collapseId">
                            <hr />

                            <p>
                                <strong>Cost:</strong>
                                @service.Cost.ToString("C")
                            </p>

                            @if (!string.IsNullOrEmpty(service.ServiceProvider))
                            {
                                <p>
                                    <strong>Service Provider:</strong>
                                    @service.ServiceProvider
                                </p>
                            }

                            @if (!string.IsNullOrEmpty(service.Description))
                            {
                                <p>
                                    <strong>Description:</strong><br />
                                    @service.Description
                                </p>
                            }

                            <div class="mt-3">
                                <a asp-action="Edit"
                                   asp-route-id="@service.ServiceHistoryId"
                                   class="btn btn-sm btn-warning">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@service.ServiceHistoryId"
                                   class="btn btn-sm btn-danger ms-2">
                                    Delete
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-controller="Vehicle"
    asp-action="Index"
    class="btn btn-secondary mt-3">
    Back to Vehicles
</a>