@model Vehicle_Service_Tracker.Models.Vehicle

@{
    ViewData["Title"] = "Add Vehicle";
}

<h2 class="mb-4">Add Vehicle</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="Year" class="form-label"></label>
            <input asp-for="Year" class="form-control" />
            <span asp-validation-for="Year" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="CurrentMileage" class="form-label"></label>
            <input asp-for="CurrentMileage" class="form-control" />
            <span asp-validation-for="CurrentMileage" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Make" class="form-label"></label>
            <input asp-for="Make" class="form-control" />
            <span asp-validation-for="Make" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Model" class="form-label"></label>
            <input asp-for="Model" class="form-control" />
            <span asp-validation-for="Model" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="LicensePlate" class="form-label"></label>
            <input asp-for="LicensePlate" class="form-control" />
            <span asp-validation-for="LicensePlate" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="VIN" class="form-label"></label>
            <input asp-for="VIN" class="form-control" />
            <span asp-validation-for="VIN" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="ImagePath" class="form-label">Image URL (optional)</label>
        <input type="file" name="imageFile" class="form-control" accept="image/*" />
        <span asp-validation-for="ImagePath" class="text-danger"></span>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success">Save Vehicle</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
