@model IEnumerable<Vehicle_Service_Tracker.Models.Vehicle>

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "My Vehicles";
}

<h2 class="mb-4">My Vehicles</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Add Vehicle
</a>

<div class="row">
    @foreach (var vehicle in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">

                @if (!string.IsNullOrEmpty(vehicle.ImagePath))
                {
                    <img src="@vehicle.ImagePath" class="card-img-top" alt="Vehicle image" />
                }
                else
                {
                    <img src="~/images/default-car.png" class="card-img-top" alt="Default car image" />
                }

                <div class="card-body">
                    <h5 class="card-title">@vehicle.Name</h5>
                    <p class="card-text text-muted">
                        @vehicle.Year @vehicle.Make @vehicle.Model
                    </p>

                    <button class="btn btn-sm btn-outline-secondary"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#details-@vehicle.VehicleId">
                        Details
                    </button>

                    <div class="collapse mt-3" id="details-@vehicle.VehicleId">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                Mileage: @vehicle.CurrentMileage km
                            </li>

                            @if (!string.IsNullOrEmpty(vehicle.LicensePlate))
                            {
                                <li class="list-group-item">
                                    Plate: @vehicle.LicensePlate
                                </li>
                            }

                            @if (!string.IsNullOrEmpty(vehicle.VIN))
                            {
                                <li class="list-group-item">
                                    VIN: @vehicle.VIN
                                </li>
                            }

                            <li class="list-group-item">
                                Added: @vehicle.DateAdded.ToShortDateString()
                            </li>
                        </ul>

                        <div class="mt-3 d-flex justify-content-between">
                            <a asp-action="Edit"
                               asp-route-id="@vehicle.VehicleId"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@vehicle.VehicleId"
                               class="btn btn-sm btn-danger">
                                Delete
                            </a>

                            <a asp-controller="ServiceHistory"
                               asp-action="Index"
                               asp-route-vehicleId="@vehicle.VehicleId"
                               class="btn btn-sm btn-info">
                                History
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>